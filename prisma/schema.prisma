  premium_rate               Decimal? @db.Decimal(5, 2)
  reinsurance_commission_pct Decimal? @db.Decimal(5, 2)
  profit_commission_pct      Decimal? @db.Decimal(5, 2)
  brokerage_fee_pct          Decimal? @db.Decimal(5, 2)

  // === Reporting & Payment ===
  reporting_participant_days Int?
  reporting_claim_days       Int?
  claim_reporting_type       String?
  payment_scenario           String?
